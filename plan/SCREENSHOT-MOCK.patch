+/**
+ * Returns a mock response if the input matches a trigger word,
+ * otherwise returns null (meaning: call the real API).
+ */
+export function getMockResponse(text: string): object | null {
+  const lower = text.trim().toLowerCase();
+  for (const [trigger, response] of Object.entries(MOCK_RESPONSES)) {
+    if (lower.includes(trigger)) return response;
+  }
+  return null;
